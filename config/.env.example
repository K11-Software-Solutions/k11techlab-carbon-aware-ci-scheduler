# ── Carbon Aware SDK ─────────────────────────────────────────────────────────
# Run the SDK locally:
#   docker run -p 8090:8090 ghcr.io/green-software-foundation/carbon-aware-sdk:latest
CARBON_SDK_BASE_URL=http://localhost:8090

# Grid zone — see Carbon Aware SDK docs for supported zones
# Examples: eastus, westus, IE, DE, FR, GB, AU-QLD
CARBON_SDK_ZONE=eastus

# gCO2eq/kWh above which to consider the grid "high carbon"
CARBON_HIGH_THRESHOLD=400

# How many hours ahead to search for a low-carbon window
CARBON_SEARCH_HOURS=6

# ── Scheduler ────────────────────────────────────────────────────────────────
# Maximum hours a deferred job can wait before running regardless of carbon
DEFERRED_TIMEOUT_HOURS=8

LOG_LEVEL=INFO

# ── QA Pipeline Integration ──────────────────────────────────────────────────
# Python module path to the QA pipeline runner
QA_PIPELINE_MODULE=k11techlab.runner

# Seconds to wait for a pipeline run before timing out
QA_PIPELINE_TIMEOUT=600
